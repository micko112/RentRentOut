<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="2-create-items-table" author="micko">
        <createTable tableName="item">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="price" type="DECIMAL(19, 2)">
                <constraints nullable="false"/>
            </column>
            <column name="days" type="INT"/>
            <column name="owner_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_item_owner" referencedTableName="user" referencedColumnNames="id"/>
            </column>
            <column name="category_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_item_category" referencedTableName="category" referencedColumnNames="id"/>
            </column>
        </createTable>
        <insert tableName="item">
            <column name="name" value="Hilti udarna busilica"/>
            <column name="description" value="HILTI Udarna busilica TOP KAO NOVA"/>
            <column name="price" valueNumeric="3000"/>
            <column name="days" valueNumeric="10"/>
            <column name="owner_id" valueNumeric="2"/>
            <column name="category_id" valueNumeric="1"/>
        </insert>
    </changeSet>

<!--    treba dodati not null kad svaki item ima lokaciju!!!!-->
    <changeSet id="3-add-location-to-item" author="micko112">
        <addColumn tableName="item">
            <column name="location_id" type="bigint"/>
        </addColumn>
        <addForeignKeyConstraint baseTableName="item" baseColumnNames="location_id" constraintName="fk_item_location"
                                 referencedTableName="location"
                                 referencedColumnNames="id"/>
    </changeSet>
    <changeSet id="4-drop-item-table" author="micko112">
        <dropTable tableName="item" cascadeConstraints="true"/>
    </changeSet>

</databaseChangeLog>