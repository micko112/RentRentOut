<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
		xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
		xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
		xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

	<changeSet id="add-currency-to-tables" author="micko112">
	<!-- Dodaj u Ad -->
	<addColumn tableName="ad">
		<column name="currency" type="VARCHAR(10)" defaultValue="RSD">
			<constraints nullable="false"/>
		</column>
	</addColumn>

	<!-- Dodaj u RentalContract -->
	<addColumn tableName="rental_contract">
		<column name="currency" type="VARCHAR(10)" defaultValue="RSD">
			<constraints nullable="false"/>
		</column>
	</addColumn>

	<!-- Dodaj u User (za ono polje 'money') -->
	<addColumn tableName="user">
		<column name="currency" type="VARCHAR(10)" defaultValue="RSD">
			<constraints nullable="false"/>
		</column>
	</addColumn>
</changeSet>
</databaseChangeLog>