<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">


    <changeSet id="7-create-rental-contract-table" author="micko112">
        <createTable tableName="rental_contract">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="ad_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_rental_ad"
                             referencedTableName="ad"
                             referencedColumnNames="id"/>
            </column>

            <column name="lessee_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_rental_lessee"
                             referencedTableName="user"
                             referencedColumnNames="id"/>
            </column>

            <column name="start_date" type="DATE">
                <constraints nullable="false"/>
            </column>

            <column name="end_date" type="DATE">
                <constraints nullable="false"/>
            </column>

            <column name="agreed_price" type="DECIMAL(19,2)">
                <constraints nullable="false"/>
            </column>

            <column name="contract_status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

	<changeSet id="2-insert-one-rental-contract" author="Luka">
		<insert tableName="rental_contract"> 
			<column name="ad_id" valueNumeric="2"/>
			<column name="lessee_id" valueNumeric="1"/>
			<column name="start_date" valueDate="2025-03-20"/>
			<column name="end_date" valueDate="2025-04-20"/>
			<column name="agreed_price" valueNumeric="7000"/>
			<column name="contract_status" value="REQUESTED"/>
		</insert>
	</changeSet>
	
		<changeSet id="3-insert-one-rental-contract" author="Luka">
		<insert tableName="rental_contract"> 
			<column name="ad_id" valueNumeric="1"/>
			<column name="lessee_id" valueNumeric="2"/>
			<column name="start_date" valueDate="2025-03-20"/>
			<column name="end_date" valueDate="2025-04-20"/>
			<column name="agreed_price" valueNumeric="78000"/>
			<column name="contract_status" value="REQUESTED"/>
		</insert>
	</changeSet>

</databaseChangeLog>

