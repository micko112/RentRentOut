<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
       http://www.liquibase.org/xml/ns/dbchangelog
       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.22.xsd">

    <changeSet id="18-add-tiered-pricing-to-ad" author="system">
        <addColumn tableName="ad">
            <column name="price_per_week" type="DECIMAL(10,2)">
                <constraints nullable="true"/>
            </column>
            <column name="price_per_month" type="DECIMAL(10,2)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
