<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
       http://www.liquibase.org/xml/ns/dbchangelog
       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.22.xsd">

    <changeSet id="1" author="luka">
        <createTable tableName="user">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="firstname" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="lastname" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="money" type="DECIMAL(19, 2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <insert tableName="user">
            <column name="email" value="luka@gmail.com"/>
            <!-- password je: luka12 -->
            <column name="password" value="$2a$10$OLBjX4KuSirnkGqNR/1e6eRdN7SmOfQFD4FutfjwdKLHAtTvSO7ui"/>
            <column name="firstname" value="Luka"/>
            <column name="lastname" value="Hadzic"/>
            <column name="money" valueNumeric="0"/>
        </insert>

        <insert tableName="user">
            <column name="email" value="micko@gmail.com"/>
            <!-- password je: micko1 -->
            <column name="password" value="$2a$10$wO0fssmD3wFtjPFwVSdiI.gseVbZim3Y1uM92idcSoxCpiG033yH2"/>
            <column name="firstname" value="Dimitrije"/>
            <column name="lastname" value="Mitic"/>
            <column name="money" valueNumeric="0"/>
        </insert>

    </changeSet>
    
    <changeSet id="2-add-role_id-column" author="Luka">
		<addColumn tableName="user">
			<column name="role_id" type="int"/>
		</addColumn>
	</changeSet>
	
	<changeSet id="3-fill-user-roles" author="Luka">
		<update tableName="user">
			<column name="role_id" valueComputed="(Select id FROM role WHERE name = 'ROLE_ADMIN')"/>
			<where>role_id IS NULL</where>
		</update>
	</changeSet>
	
	<changeSet id="4-creating-foreign-key" author="Luka">
		<addForeignKeyConstraint baseTableName="user" 
		baseColumnNames="role_id" 
		constraintName="fk_user_role" 
		referencedTableName="role" 
		referencedColumnNames="id"/>
	</changeSet>
	
	<changeSet id="5-setting-foreign-key-to-notnull" author="Luka">
		<addNotNullConstraint tableName="user" columnName="role_id" columnDataType="int"/>
	</changeSet>
	
	<changeSet id="6-adding-one-more-user" author="Luka">
		        <insert tableName="user">
            <column name="email" value="zeljko@gmail.com"/>
            <!-- password wrong - fixed in next changeset-->
            <column name="password" value="'$2a$10$epbDIv53YAFT.OToIpKS1.XeYOHT91xDPdbOp8fkUnwr9TkjIR2Ca'"/>
            <column name="firstname" value="Zeljko"/>
            <column name="lastname" value="Stojkovic"/>
            <column name="money" valueNumeric="0"/>
            <column name="role_id" value="2"/>
        </insert>
	</changeSet>
	
	<changeSet id="7-change-users-password" author="Luka">
		<update tableName="user">
			<column name="password" value="$2a$10$epbDIv53YAFT.OToIpKS1.XeYOHT91xDPdbOp8fkUnwr9TkjIR2Ca"/>
			<where>email = 'zeljko@gmail.com'</where>
		</update>
	</changeSet>
	
	<changeSet id="8-add-enabled-column-for-email-verification" author="Luka">
		<addColumn tableName="user">
			<column name="enabled" type="BOOLEAN"/>
		</addColumn>
	</changeSet>
	
	<changeSet id="9-fill-enabled-column" author="Luka">
		<update tableName="user">
			<column name="enabled" valueBoolean="true"></column>
		</update>
	</changeSet>
	
	<changeSet id="10-make-default-value-for-enabled" author="Luka">
		
		<addDefaultValue tableName="user" columnName="enabled" 
		columnDataType="BOOLEAN" defaultValueBoolean="false"/>
		
		<addNotNullConstraint tableName="user" columnName="enabled" columnDataType="BOOLEAN"/>
		
	</changeSet>
	
	<changeSet id="11-add-version-enable-optimistic" author="Luka">
		<addColumn tableName="user">
			<column name="version" type="BIGINT"></column>
		</addColumn>
		
		<update tableName="user">
			<column name="version" valueNumeric="0"></column>
		</update>
		
		<addNotNullConstraint tableName="user" columnName="version" columnDataType="BIGINT"/>
		
	</changeSet>
	
</databaseChangeLog>