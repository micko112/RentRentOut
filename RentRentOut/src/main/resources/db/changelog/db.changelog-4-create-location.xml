<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="5-create-location" author="micko112">
        <createTable tableName="location">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="country" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="city" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="municipality" type="VARCHAR(255)"/>

            <column name="lat" type="DECIMAL(10,7)"/>
            <column name="lng" type="DECIMAL(10,7)"/>
        </createTable>
    </changeSet>

<!--    <changeSet id="6-drop-location-id-from-location" author="micko112">-->
<!--        <dropColumn tableName="location" columnName="location_id"/>-->
<!--    </changeSet>-->
    <changeSet id="7-insert-initial-locations" author="micko112">

        <insert tableName="location">
            <column name="country" value="Srbija"/>
            <column name="city" value="Beograd"/>
            <column name="municipality" value="Vračar"/>
            <column name="lat" valueNumeric="44.7975018"/>
            <column name="lng" valueNumeric="20.4741334"/>
        </insert>

        <insert tableName="location">
            <column name="country" value="Srbija"/>
            <column name="city" value="Beograd"/>
            <column name="municipality" value="Vozdovac"/>
            <column name="lat" valueNumeric="44.7451172"/>
            <column name="lng" valueNumeric="20.4881893"/>
        </insert>
    </changeSet>

</databaseChangeLog>