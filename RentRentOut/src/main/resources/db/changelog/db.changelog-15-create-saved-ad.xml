<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.22.xsd">

    <changeSet id="15.1-create-saved-ad-table" author="micko112">
        <createTable tableName="saved_ad">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_saved_ad_user"
                             referencedTableName="user"
                             referencedColumnNames="id"/>
            </column>
            <column name="ad_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_saved_ad_ad"
                             referencedTableName="ad"
                             referencedColumnNames="id"/>
            </column>
            <column name="saved_at" type="DATETIME" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="15.2-saved-ad-unique-constraint" author="micko112">
        <addUniqueConstraint tableName="saved_ad"
                             columnNames="user_id, ad_id"
                             constraintName="uq_saved_ad_user_ad"/>
    </changeSet>

</databaseChangeLog>
