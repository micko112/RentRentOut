<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
		xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
		xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
		xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

	<changeSet id="7-create-rental-contract-table-final" author="micko112">
		<createTable tableName="rental_contract">
			<column name="id" type="BIGINT" autoIncrement="true">
				<constraints primaryKey="true" nullable="false"/>
			</column>

			<column name="ad_id" type="BIGINT">
				<constraints nullable="false" foreignKeyName="fk_rental_ad" referencedTableName="ad" referencedColumnNames="id"/>
			</column>

			<column name="lessee_id" type="BIGINT">
				<constraints nullable="false" foreignKeyName="fk_rental_lessee" referencedTableName="user" referencedColumnNames="id"/>
			</column>

			<column name="start_date" type="DATE">
				<constraints nullable="false"/>
			</column>

			<column name="end_date" type="DATE">
				<constraints nullable="false"/>
			</column>

			<column name="agreed_price" type="DECIMAL(19,2)">
				<constraints nullable="false"/>
			</column>

			<column name="contract_status" type="VARCHAR(50)">
				<constraints nullable="false"/>
			</column>

			<!-- Nove kolone zgnječene ovde -->
			<column name="offer_sender_id" type="BIGINT">
				<constraints nullable="false" foreignKeyName="fk_offer_sender_id" referencedTableName="user" referencedColumnNames="id" />
			</column>

			<column name="amount" type="INT" defaultValueNumeric="1">
				<constraints nullable="false"/>
			</column>

			<column name="currency" type="VARCHAR(16)" defaultValue="RSD">
				<constraints nullable="false"/>
			</column>
		</createTable>
	</changeSet>

</databaseChangeLog>