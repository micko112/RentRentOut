<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
       http://www.liquibase.org/xml/ns/dbchangelog
       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.22.xsd">

	<changeSet id="1-create-password-reset-token-table" author="Uros">
		<createTable tableName="password_reset_token">
			<column name="id" type="BIGINT" autoIncrement="true">
				<constraints primaryKey="true" nullable="false"/>
			</column>
			<column name="token" type="VARCHAR(255)">
				<constraints unique="true" nullable="false"/>
			</column>
			<column name="expires_at" type="DATE">
				<constraints nullable="false"/>
			</column>
			<column name="user_id" type="BIGINT">
				<constraints nullable="false" foreignKeyName="fk_user_id_in_password_reset"
				referencedTableName="user" referencedColumnNames="id"/>
			</column>
			<column name="used" type="BOOLEAN" defaultValueBoolean="false">
				<constraints nullable="false"/>
			</column>
		</createTable>
	</changeSet>
</databaseChangeLog>
