<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.22.xsd">

    <changeSet id="14.1-add-view-count-to-ad" author="micko112">
        <addColumn tableName="ad">
            <column name="view_count" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="14.2-create-ad-view-table" author="micko112">
        <createTable tableName="ad_view">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_ad_view_user"
                             referencedTableName="user"
                             referencedColumnNames="id"/>
            </column>
            <column name="ad_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_ad_view_ad"
                             referencedTableName="ad"
                             referencedColumnNames="id"/>
            </column>
            <column name="viewed_at" type="DATETIME" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="14.3-ad-view-unique-constraint" author="micko112">
        <addUniqueConstraint tableName="ad_view"
                             columnNames="user_id, ad_id"
                             constraintName="uq_ad_view_user_ad"/>
    </changeSet>

</databaseChangeLog>
