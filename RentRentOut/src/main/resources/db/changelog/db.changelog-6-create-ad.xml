<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">


    <changeSet id="6-create-ad" author="micko112">
        <createTable tableName="ad">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="price" type="DECIMAL(19, 2)">
                <constraints nullable="false"/>
            </column>
            <column name="price_interval" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="ad_status" type="VARCHAR(50)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="total_quantity" type="INT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="available_quantity" type="INT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="owner_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_ad_owner" referencedTableName="user" referencedColumnNames="id"/>
            </column>
            <column name="category_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_ad_category" referencedTableName="category" referencedColumnNames="id"/>
            </column>
            <column name="location_id" type="BIGINT">
                <constraints nullable="true" foreignKeyName="fk_ad_location" referencedTableName="location" referencedColumnNames="id"/>
            </column>
        </createTable>
        <insert tableName="ad">
            <column name="title" value="Izdaje se stan na dan - Vračar"/>
            <column name="description" value="Kompletno opremljen stan u srcu Vračara, idealan za 2 osobe. Klima, Wi-Fi, kablovska. Blizu Hrama Svetog Save."/>
            <column name="price" valueNumeric="5000.00"/>
            <column name="price_interval" value="PER_DAY"/>
            <column name="ad_status" value="ACTIVE"/>

            <column name="total_quantity" valueNumeric="1"/>
            <column name="available_quantity" valueNumeric="1"/>

            <column name="owner_id" valueNumeric="1"/>     <!-- ID korisnika 'Luka' -->
            <column name="category_id" valueNumeric="3"/>  <!-- ID kategorije 'Nekretnine' -->
            <column name="location_id" valueNumeric="1"/>  <!-- ID neke lokacije -->
        </insert>

        <insert tableName="ad">
            <column name="title" value="Iznajmljivanje profesionalne Hilti bušilice"/>
            <column name="description" value="Model TE 70-AVR. Dolazi sa kompletom burgija za beton. Moguće iznajmljivanje više komada odjednom."/>
            <column name="price" valueNumeric="2500.00"/>
            <column name="price_interval" value="PER_DAY"/>
            <column name="ad_status" value="ACTIVE"/>

            <column name="total_quantity" valueNumeric="15"/>
            <column name="available_quantity" valueNumeric="15"/>

            <column name="owner_id" valueNumeric="2"/>
            <column name="category_id" valueNumeric="1"/>
            <column name="location_id" valueNumeric="2"/>
        </insert>
    </changeSet>
    <changeSet id="7-create-ad-image-table" author="micko112">
        <createTable tableName="ad_image">
            <column name="ad_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_adimage_ad" referencedTableName="ad" referencedColumnNames="id"/>
            </column>
            <column name="image_url" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>

