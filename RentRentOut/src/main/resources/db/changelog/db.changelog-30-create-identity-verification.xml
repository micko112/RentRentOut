<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="30-create-identity-verification" author="landm">
        <createTable tableName="identity_verification">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"
                             unique="true"
                             foreignKeyName="fk_verification_user"
                             references="user(id)"
                             deleteCascade="true"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="doc_front_public_id" type="VARCHAR(255)"/>
            <column name="doc_back_public_id" type="VARCHAR(255)"/>
            <column name="selfie_public_id" type="VARCHAR(255)"/>
            <column name="submitted_at" type="DATETIME" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="reviewed_at" type="DATETIME"/>
            <column name="rejection_reason" type="VARCHAR(300)"/>
            <column name="reviewed_by" type="BIGINT">
                <constraints foreignKeyName="fk_verification_reviewer"
                             references="user(id)"/>
            </column>
        </createTable>

        <createIndex tableName="identity_verification" indexName="idx_verification_status">
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
