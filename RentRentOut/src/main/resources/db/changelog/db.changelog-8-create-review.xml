<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
       http://www.liquibase.org/xml/ns/dbchangelog
       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.22.xsd">

	<changeSet id="7.2-create-review-table" author="micko112">
		<createTable tableName="review">
			<column name="id" type="BIGINT" autoIncrement="true">
				<constraints primaryKey="true" nullable="false"/>
			</column>

			<!-- Ugovor na koji se ocena odnosi -->
			<column name="contract_id" type="BIGINT">
				<constraints nullable="false" foreignKeyName="fk_review_contract" referencedTableName="rental_contract" referencedColumnNames="id"/>
			</column>

			<!-- Ko ostavlja ocenu -->
			<column name="reviewer_id" type="BIGINT">
				<constraints nullable="false" foreignKeyName="fk_review_reviewer" referencedTableName="user" referencedColumnNames="id"/>
			</column>

			<!-- Ko dobija ocenu -->
			<column name="reviewee_id" type="BIGINT">
				<constraints nullable="false" foreignKeyName="fk_review_reviewee" referencedTableName="user" referencedColumnNames="id"/>
			</column>

			<!-- TRI KLJUČNA PITANJA (Čuvamo kao String/Enum) -->
			<column name="payment_ok" type="VARCHAR(20)"><constraints nullable="false"/></column>
			<column name="communication_ok" type="VARCHAR(20)"><constraints nullable="false"/></column>
			<column name="agreement_ok" type="VARCHAR(20)"><constraints nullable="false"/></column>

			<!-- FINALNI IZRAČUNATI TIP (POSITIVE / NEGATIVE) -->
			<column name="review_type" type="VARCHAR(20)"><constraints nullable="false"/></column>

			<!-- Tekstualni komentar (opciono) -->
			<column name="comment" type="TEXT"/>

			<!-- Kada je ocena ostavljena -->
			<column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
				<constraints nullable="false"/>
			</column>
		</createTable>
	</changeSet>

	<changeSet id="7.3-add-unique-constraint-to-review" author="micko112">
		<!-- Ovo osigurava da jedan 'reviewer' za jedan 'contract' može ostaviti samo JEDAN red u bazi -->
		<addUniqueConstraint tableName="review"
							 columnNames="contract_id, reviewer_id"
							 constraintName="uq_review_per_contract_reviewer"/>
	</changeSet>
</databaseChangeLog>