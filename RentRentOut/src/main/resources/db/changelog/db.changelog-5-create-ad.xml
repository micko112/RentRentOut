<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="6-create-ad-tables-final" author="micko112">
        <!-- Kreiranje tabele Oglasi (ad) -->
        <createTable tableName="ad">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="price" type="DECIMAL(19, 2)">
                <constraints nullable="false"/>
            </column>
            <column name="price_interval" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="ad_status" type="VARCHAR(50)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="total_quantity" type="INT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>

            <!-- Nova kolona zgnječena u kreiranje tabele -->
            <column name="currency" type="VARCHAR(16)" defaultValue="RSD">
                <constraints nullable="false"/>
            </column>

            <!-- Strani ključevi -->
            <column name="owner_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_ad_owner" referencedTableName="user" referencedColumnNames="id"/>
            </column>
            <column name="category_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_ad_category" referencedTableName="category" referencedColumnNames="id"/>
            </column>
            <column name="location_id" type="BIGINT">
                <constraints nullable="true" foreignKeyName="fk_ad_location" referencedTableName="location" referencedColumnNames="id"/>
            </column>
        </createTable>

        <!-- Kreiranje tabele za slike (odmah ovde, jer usko zavisi od 'ad') -->
        <createTable tableName="ad_image">
            <column name="ad_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_adimage_ad" referencedTableName="ad" referencedColumnNames="id"/>
            </column>
            <column name="image_url" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>