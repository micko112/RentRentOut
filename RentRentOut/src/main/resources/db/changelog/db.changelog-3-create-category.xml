<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">


        <changeSet id="3-create-category-table" author="micko">
                <createTable tableName="category">
                    <column name="id" type="BIGINT" autoIncrement="true">
                        <constraints primaryKey="true" nullable="false"/>
                    </column>
                    <column name="name" type="VARCHAR(100)">
                        <constraints nullable="false" unique="true"/>
                    </column>
                    <column name="parent_id" type="BIGINT">
                        <constraints foreignKeyName="fk_category_parent" referencedTableName="category" referencedColumnNames="id"/>
                    </column>
                </createTable>

            <insert tableName="category">
                <column name="name" value="Alati"/>
            </insert>
            <insert tableName="category">
                <column name="name" value="Nekretnine"/>
            </insert>
            <insert tableName="category">
                <column name="name" value="Stanovi"/>
                <column name="parent_id" value="2"/>
            </insert>
            <insert tableName="category">
                <column name="name" value="Vozila"/>
            </insert>
            </changeSet>



        </databaseChangeLog>